@model Bai6_Tuan6_LTW.Models.Product

<h4>CHỈNH SỬA SẢN PHẨM</h4>
<hr />
<div asp-validation-summary="All" class="text-danger"></div>

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ImageUrl" />

    <div class="form-group mb-3">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label asp-for="Price"></label>
        <input asp-for="Price" class="form-control" />
    </div>
    <div class="form-group mb-3">
        <label asp-for="Description"></label>
        <textarea asp-for="Description" class="form-control"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label>Hình ảnh hiện tại</label><br />
        <img src="@Model.ImageUrl" width="150" class="img-thumbnail mb-2" />
        <br />
        <label>Thay đổi ảnh mới (nếu muốn)</label>
        <input type="file" name="productImage" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label>Danh mục</label>
        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-control"></select>
    </div>

    <div class="form-group">
        <button type="submit" class="btn btn-success">Cập nhật</button>
        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
    </div>
    
</form>