@model IEnumerable<Bai6_Tuan6_LTW.Models.Product>

@{
    ViewData["Title"] = "Cửa Hàng Sành Điệu";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <h2 class="text-uppercase fw-bold text-primary">Danh sách sản phẩm</h2>
        @* 1. Nút Thêm mới: Chỉ Admin mới thấy *@
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary shadow-sm rounded-pill px-4">
                <i class="bi bi-plus-circle"></i> Thêm mới
            </a>
        }
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 shadow border-0 product-card transition-hover">
                    <div class="position-relative overflow-hidden" style="height: 220px; background-color: #f8f9fa;">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" class="card-img-top w-100 h-100 object-fit-contain p-2" alt="@item.Name">
                        }
                        else
                        {
                            <div class="w-100 h-100 d-flex align-items-center justify-content-center text-muted">
                                <i class="bi bi-image" style="font-size: 3rem;"></i>
                            </div>
                        }
                        <div class="card-img-overlay d-flex align-items-start justify-content-end p-2">
                             <span class="badge bg-danger shadow-sm rounded-pill">Hot</span>
                        </div>
                    </div>

                    <div class="card-body d-flex flex-column p-3">
                        <h6 class="card-title fw-bold text-truncate mb-1" title="@item.Name">
                            <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none text-dark hover-primary">
                                @item.Name
                            </a>
                        </h6>
                        
                        <p class="card-text text-danger fs-5 fw-bold mb-3 mt-1">
                            @item.Price.ToString("N0") <span class="fs-6 fw-normal">đ</span>
                        </p>
                        
                        <div class="mt-auto pt-2 border-top">
                            @* --- NÚT ADD TO CART: To và nổi bật nhất --- *@
                            <a asp-controller="ShoppingCart" asp-action="AddToCart" asp-route-productId="@item.Id" 
                               class="btn btn-primary w-100 mb-2 py-2 fw-bold text-uppercase shadow-sm">
                                <i class="bi bi-cart-plus-fill"></i> Thêm vào giỏ
                            </a>

                            <div class="d-flex gap-1 justify-content-between action-buttons">
                                @* 3. Nút Chi tiết: Ai cũng thấy *@
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm flex-grow-1 rounded-pill">
                                    <i class="bi bi-eye"></i> Chi tiết
                                </a>

                                @* 2 & 4. Nút Sửa/Xóa: Chỉ Admin mới thấy *@
                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm rounded-pill">
                                        <i class="bi bi-pencil-square"></i> Sửa
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm rounded-pill">
                                        <i class="bi bi-trash"></i> Xóa
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    /* Hiệu ứng nhấc thẻ khi rê chuột vào */
    .transition-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .transition-hover:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.15) !important;
    }

    /* Đảm bảo hình ảnh không bị méo */
    .object-fit-contain {
        object-fit: contain; /* Hoặc cover nếu muốn ảnh lấp đầy khung */
    }

    /* Hiệu ứng màu khi rê chuột vào tên sản phẩm */
    .hover-primary:hover {
        color: #0d6efd !important;
    }

    /* Bo góc cho nút bấm cho mềm mại */
    .btn-sm.rounded-pill {
        padding-left: 10px;
        padding-right: 10px;
    }
    
    /* Ẩn các nút Sửa/Xóa/Chi tiết trên màn hình quá nhỏ để đỡ rối */
    @@media (max-width: 576px) {
        .action-buttons {
            flex-wrap: wrap;
        }
    }
</style>