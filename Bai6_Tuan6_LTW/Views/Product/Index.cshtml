@model IEnumerable<Bai6_Tuan6_LTW.Models.Product>

@{
    ViewData["Title"] = "Danh sách Sản phẩm";
}

<h1>Danh sách Sản phẩm</h1>

@* 1. Kiểm tra nếu là Admin mới hiện nút Thêm mới *@
@if (User.IsInRole("Admin"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Thêm mới</a>
    </p>
}

<table class="table">
    <thead>
        <tr>
            <th>Tên sản phẩm</th>
            <th>Giá</th>
            <th>Hình ảnh</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Price.ToString("N0") đ</td>
                <td>
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" width="100" class="img-thumbnail" />
                    }
                </td>
                <td>
                    @* 2. Nút Sửa: Chỉ Admin mới thấy *@
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning">Sửa</a>
                    }

                    @* 3. Nút Chi tiết: Ai cũng thấy *@
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info">Chi tiết</a>

                    @* 4. Nút Xóa: Chỉ Admin mới thấy *@
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">Xóa</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>