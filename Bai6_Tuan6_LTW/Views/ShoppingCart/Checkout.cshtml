@model Bai6_Tuan6_LTW.Models.Order

@{
    ViewData["Title"] = "Thanh toán";
}

<h2>Thông tin thanh toán</h2>

<form asp-action="Checkout" method="post">
    <div class="form-group">
        <label>Địa chỉ giao hàng</label>
        <input asp-for="ShippingAddress" class="form-class" required />
    </div>
    <div class="form-group mt-2">
        <label>Ghi chú</label>
        <textarea asp-for="Notes" class="form-control"></textarea>
    </div>

    <h4 class="mt-3">Xác nhận đơn hàng</h4>
    <button type="submit" class="btn btn-primary mt-2">Xác nhận đặt hàng</button>
</form>